{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/stillness-that-walks/(.*)",
      "destination": "/stillness-that-walks/index.html"
    },
    {
      "source": "/hening-yang-berjalan/(.*)",
      "destination": "/hening-yang-berjalan/index.html"
    },
    {
      "source": "/ache-what-kind-of-life-is-this/(.*)",
      "destination": "/ache-what-kind-of-life-is-this/index.html"
    },
    {
      "source": "/ache-hidup-seperti-apa-ini/(.*)",
      "destination": "/ache-hidup-seperti-apa-ini/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/BingSiteAuth.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
