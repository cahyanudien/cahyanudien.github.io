{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/stillness-that-walks/(.*)",
      "destination": "/stillness-that-walks/index.html"
    },
    {
      "source": "/hening-yang-berjalan/(.*)",
      "destination": "/hening-yang-berjalan/index.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
